<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:include filename="inertial_macros.xacro"/>

    <material name="white">
        <color rgba="1 1 1 1"/>
    </material>
    
    <material name="black">
        <color rgba="0 0 0 1"/>
    </material>

    <material name="red">
        <color rgba="1 0 0 1"/>
    </material>

    <material name="green">
        <color rgba="0 1 0 1"/>
    </material>

    <material name="blue">
        <color rgba="0 0 1 1"/>
    </material>

    <material name="orange">
        <color rgba="1 0.5 0 1"/>
    </material>

    <!-- Base link -->

    <link name="base_link">

    </link>

    <joint name="chassis_joint" type="fixed">
        <parent link="base_link"/>
        <child link="chassis"/>
        <origin xyz="0 0 0"/>
    </joint>

    <!-- Chassis -->
    <link name="chassis">
        <visual>
            <origin xyz="0.125 0 0.0625"/>
            <geometry>
                <box size="0.25 0.25 0.045"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0.125 0 0.0625"/>
            <geometry>
                <box size="0.25 0.25 0.045"/>
            </geometry>
        </collision>
        <xacro:inertial_box mass="0.5" x="0.25" y="0.25" z="0.045">
            <origin xyz="0.125 0 0.0625" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <gazebo reference="chassis">
        <material>Gazebo/Blue</material>
    </gazebo>

    <!-- Left Wheel -->
    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel"/>
        <origin xyz="0.125 0.142 0.0425" rpy="-${pi/2} 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>
    <link name="left_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.0425" length="0.0334"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.0425" length="0.0334"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.1" length="0.0334" radius="0.0425">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="left_wheel">
        <material>Gazebo/Black</material>
    </gazebo>

    <!-- Right Wheel -->
    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <origin xyz="0.125 -0.142 0.0425" rpy="${pi/2} 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>
    <link name="right_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.0425" length="0.0334"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.0425" length="0.0334"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.1" length="0.0334" radius="0.0425">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="right_wheel">
        <material>Gazebo/Black</material>
    </gazebo>


    <!-- Caster Wheel 1-->
    <joint name="caster_wheel_1_joint" type="fixed">
    <parent link="chassis"/>
    <child link="caster_wheel_1"/>
    <origin xyz="0.23 0.1 0.02" rpy="0 0 0"/>
    </joint>

    <link name="caster_wheel_1">
        <visual>
            <geometry>
                <sphere radius="0.02"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="0.02"/>
            </geometry>
        </collision>
        <xacro:inertial_sphere mass="0.1" radius="0.02">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_sphere>
    </link>

    <gazebo reference="caster_wheel_1">
        <material>Gazebo/Black</material>
    </gazebo>

    <!-- Caster Wheel 2-->
    <joint name="caster_wheel_2_joint" type="fixed">
    <parent link="chassis"/>
    <child link="caster_wheel_2"/>
    <origin xyz="0.23 -0.1 0.02" rpy="${pi/2} 0 0"/>
    </joint>

    <link name="caster_wheel_2">
        <visual>
            <geometry>
                <sphere radius="0.02"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="0.02"/>
            </geometry>
        </collision>
            <xacro:inertial_sphere mass="0.1" radius="0.02">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_sphere>
    </link>

    <gazebo reference="caster_wheel_2">
        <material>Gazebo/Black</material>
    </gazebo>

    <!-- Caster Wheel 3 (Back Left) -->
<joint name="caster_wheel_3_joint" type="fixed">
    <parent link="chassis"/>
    <child link="caster_wheel_3"/>
    <origin xyz="0.02 0.1 0.02" rpy="0 0 0"/>
</joint>

<link name="caster_wheel_3">
    <visual>
        <geometry>
            <sphere radius="0.02"/>
        </geometry>
        <material name="black"/>
    </visual>
    <collision>
        <geometry>
            <sphere radius="0.02"/>
        </geometry>
    </collision>
    <xacro:inertial_sphere mass="0.1" radius="0.02">
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_sphere>
</link>

<gazebo reference="caster_wheel_3">
    <material>Gazebo/Black</material>
</gazebo>

<!-- Caster Wheel 4 (Back Right) -->
<joint name="caster_wheel_4_joint" type="fixed">
    <parent link="chassis"/>
    <child link="caster_wheel_4"/>
    <origin xyz="0.02 -0.1 0.02" rpy="${pi/2} 0 0"/>
</joint>

<link name="caster_wheel_4">
    <visual>
        <geometry>
            <sphere radius="0.02"/>
        </geometry>
        <material name="black"/>
    </visual>
    <collision>
        <geometry>
            <sphere radius="0.02"/>
        </geometry>
    </collision>
    <xacro:inertial_sphere mass="0.1" radius="0.02">
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_sphere>
</link>

<gazebo reference="caster_wheel_4">
    <material>Gazebo/Black</material>
</gazebo>


</robot>
